HF_HOME=./modelsweights/huggingface
HF_HUB_DISABLE_XET=1
# Set to 1 when the model has already been downloaded and runtime must not access the Hub.
# ROLETONE_LOCAL_FILES_ONLY=1
# Optional: if set, this is passed to transformers from_pretrained(cache_dir=...).
# ROLETONE_CACHE_DIR=./modelsweights/transformers-cache

# Recommended for speaker/timbre similarity.
ROLETONE_MODEL=wavlm-base-plus-sv

# auto chooses xvector for *-sv models and pooled WavLM embeddings for base/large.
ROLETONE_EMBEDDING_MODE=auto
ROLETONE_DEVICE=auto
ROLETONE_SAMPLE_RATE=16000
ROLETONE_TRIM_TOP_DB=30

# Raw cosine thresholds. Tune them with your own known-good/known-bad samples.
ROLETONE_MATCH_THRESHOLD=0.86
ROLETONE_LIKELY_THRESHOLD=0.75
ROLETONE_BORDERLINE_THRESHOLD=0.65
